# Environment Configuration for NAME IT SCENTS Backend

# Server Configuration
# Default 3030 avoids clashes with PostgreSQL/tools on 3000 and other Node apps on 3001
PORT=3030
NODE_ENV=development
JWT_SECRET=replace_with_a_strong_secret_at_least_32_chars

# CORS Configuration (origins allowed to call the API — your static site / Live Server ports)
# Include both localhost and 127.0.0.1 with port — browsers treat them as different origins.
CORS_ORIGIN=http://localhost:3030,http://localhost:5500,http://localhost:8080,http://127.0.0.1:5500,http://127.0.0.1:8080

# Frontend URL (used by backend links if needed)
FRONTEND_URL=http://localhost:5500

# Firebase Configuration (for Firebase Admin SDK)
# This should match your service-account.json
FIREBASE_PROJECT_ID=name-it-e674c
# For Render/production, paste your full Firebase service account JSON as a single-line string:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}

# Optional: Database Configuration
DATABASE_URL=your_database_url_here

# Optional: Email Configuration (for order notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Optional: Admin Contact Information
ADMIN_EMAIL=admin@nameitscents.com
ADMIN_PHONE=+1234567890

# Payment Configuration
PAYMENT_TIMEOUT=900000
PAYMENT_RETRY_ATTEMPTS=3

# --- TASH chatbot (production-oriented) ---
GEMINI_API_KEY=your_gemini_key_here
# Optional overrides:
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_TIMEOUT_MS=25000
# CHAT_SESSION_TTL_MS=604800000
# CHAT_RATE_LIMIT_MAX=30
# CHAT_RATE_LIMIT_WINDOW_MS=60000
# Redis for distributed rate limits (recommended when running multiple API instances):
# REDIS_URL=redis://127.0.0.1:6379
# GET /api/chat/metrics with header x-chat-metrics-key (hide or rotate in production):
# CHAT_METRICS_SECRET=long_random_string
